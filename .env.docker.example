# Copy this to .env and fill in your values before running docker-compose

# Database password (used by both postgres and the app)
DB_PASSWORD=changeme

# Port to expose the app on (default: 3000)
PORT=3000

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Discord OAuth (https://discord.com/developers/applications)
BETTER_AUTH_DISCORD_CLIENT_ID=
BETTER_AUTH_DISCORD_CLIENT_SECRET=

# TMDB API Bearer token (https://www.themoviedb.org/settings/api)
TMDB_BEARER=

# Jellyseerr (optional)
JELLYSEER_URL=
JELLYSEER_API_KEY=
