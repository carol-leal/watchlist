// Prisma schema for Better Auth
// learn more: https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// NOTE: When using mysql or sqlserver, uncomment the //@db.Text annotations in model Account below
// Further reading:
// https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id
  name             String //@db.Text
  email            String
  emailVerified    Boolean         @default(false)
  image            String? //@db.Text
  discordUsername  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @default(now()) @updatedAt
  sessions         Session[]
  accounts         Account[]
  playlistUsers    PlaylistUser[]
  createdPlaylists Playlist[]      @relation("createdBy")
  addedMovies      Movie[]         @relation("addedBy")
  createdMovies    Movie[]         @relation("createdBy")
  addedSeries      Series[]        @relation("addedBy")
  createdSeries    Series[]        @relation("createdBy")
  sentInvitations     PlaylistInvitation[] @relation("sentInvitations")
  receivedInvitations PlaylistInvitation[] @relation("receivedInvitations")
  activityLogs     ActivityLog[]
  preferences      UserPreferences?

  @@unique([email])
  @@map("user")
}

model UserPreferences {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  showListStats     Boolean @default(true)
  statusSelectMode  String  @default("dropdown") // "dropdown" | "buttons"
  defaultPlaylistId String?

  @@map("user_preferences")
}

model Playlist {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  description        String? //@db.Text
  jellyseerrEnabled  Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  users       PlaylistUser[]
  invitations PlaylistInvitation[]
  movies      Movie[]
  series      Series[]
  activityLogs ActivityLog[]

  createdBy   User   @relation("createdBy", fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

model Movie {
  id          String    @id @default(cuid())
  tmdbId      Int?
  title       String
  description String? //@db.Text
  image       String? //@db.Text
  releaseDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  status      Status    @default(PENDING)
  tags        String[] //@db.Text
  tmdbScore   Float?
  addedById   String
  addedBy     User      @relation("addedBy", fields: [addedById], references: [id])

  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  createdBy   User   @relation("createdBy", fields: [createdById], references: [id])
  createdById String

  @@unique([playlistId, tmdbId])
  @@index([title])
}

model Series {
  id             String    @id @default(cuid())
  tmdbId         Int?
  title          String
  description    String? //@db.Text
  image          String? //@db.Text
  releaseDate    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  status         Status    @default(PENDING)
  tags           String[] //@db.Text
  tmdbScore      Float?
  currentSeason  Int       @default(1)
  currentEpisode Int       @default(1)
  addedById   String
  addedBy     User      @relation("addedBy", fields: [addedById], references: [id])

  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  createdBy   User   @relation("createdBy", fields: [createdById], references: [id])
  createdById String

  @@unique([playlistId, tmdbId])
  @@index([title])
}

model PlaylistUser {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([playlistId, userId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model PlaylistInvitation {
  id              String           @id @default(cuid())
  playlistId      String
  playlist        Playlist         @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  discordUsername String
  invitedById     String
  invitedBy       User             @relation("sentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUserId   String?
  invitedUser     User?            @relation("receivedInvitations", fields: [invitedUserId], references: [id], onDelete: Cascade)
  status          InvitationStatus @default(PENDING)
  createdAt       DateTime         @default(now())

  @@unique([playlistId, discordUsername])
  @@map("playlist_invitation")
}

enum Status {
  PENDING
  WATCHING
  WATCHED
  DROPPED
}

model ActivityLog {
  id         String   @id @default(cuid())
  type       String   // MOVIE_ADDED, STATUS_CHANGED, MOVIE_DELETED, MEMBER_JOINED, MEMBER_REMOVED, SERIES_ADDED
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movieTitle String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([playlistId])
  @@index([createdAt])
  @@map("activity_log")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String? //@db.Text
  userAgent String? //@db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String //@db.Text
  providerId            String //@db.Text
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String? //@db.Text
  refreshToken          String? //@db.Text
  idToken               String? //@db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String? //@db.Text
  password              String? //@db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String //@db.Text
  value      String //@db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}
